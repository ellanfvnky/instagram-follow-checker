{
  "manifest_version": 3,
  "name": "IG Follow Checker — Local & Private",
  "version": "1.0.0",
  "description": "Analisis followers & following Instagram: Not Follow Back, Fans, Unfollowers, New Followers. 100% lokal, tanpa login tambahan.",
  "minimum_chrome_version": "110",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "IG Follow Checker"
  },
  "options_page": "dashboard.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "tabs", "alarms", "downloads", "declarativeNetRequest"],
  "host_permissions": ["https://www.instagram.com/*", "*://*.cdninstagram.com/*", "*://*.fbcdn.net/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
